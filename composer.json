{
    "name": "unomns/centrifugo-laravel",
    "description": "Laravel package for Centrifugo WebSocket proxy integration",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "centrifugal/phpcent": "~6.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/cache": "^10.0|^11.0|^12.0",
        "illuminate/log": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "mockery/mockery": "^1.6",
        "larastan/larastan": "^2.0",
        "laravel/pint": "^1.0"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "analyse": "./vendor/bin/phpstan analyse",
        "format": "./vendor/bin/pint",
        "format:check": "./vendor/bin/pint --test"
    },
    "autoload": {
        "psr-4": {
            "Unomns\\Centrifugo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Unomns\\Centrifugo\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Unomns\\Centrifugo\\CentrifugoServiceProvider"
            ],
            "aliases": {
                "Centrifugo": "Unomns\\Centrifugo\\Facades\\Centrifugo"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
